# TrendPulse live lead API configuration
# Copy this file to server/.env and fill in your credentials.
# server/.env is gitignored — never commit real keys.

# Port for the local lead API (Vite proxies /api to this).
PORT=8787

# Reddit OAuth (free). Create a "script" app at https://www.reddit.com/prefs/apps
# App-only client_credentials grant is used — no personal password needed.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=web:trendpulse-lead-miner:v1.0 (by /u/your_reddit_username)

# Hacker News and Google Trends need NO keys.
